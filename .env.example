# HeroFrame AI — environment variables (example)
# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# Google AI (Gemini) — vision analysis, prompt expansion, chat refinement
# Create a key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional aliases (any one works if GOOGLE_GENERATIVE_AI_API_KEY is unset):
# GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=

# Optional: model id (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Image pixels: Google Gemini image API by default (same key as GOOGLE_GENERATIVE_AI_API_KEY).
# Replicate is optional — only used if you opt in (see below) or if no Google key is set.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_IMAGE_ASPECT=4:5
# GEMINI_IMAGE_SIZE=1K

# Replicate — only when ADSME_USE_REPLICATE=1 or IMAGE_GENERATION_BACKEND=replicate
REPLICATE_API_TOKEN=
# ADSME_USE_REPLICATE=1
# IMAGE_GENERATION_BACKEND=replicate

# Generation model (see src/app/api/ai/generate/route.ts)
# Product-aware (default): black-forest-labs/flux-kontext-max
# Fast text-only scene: black-forest-labs/flux-schnell
# REPLICATE_MODEL=black-forest-labs/flux-kontext-max
# REPLICATE_KONTEXT_ASPECT=match_input_image
# REPLICATE_SCHNELL_ASPECT=4:5
